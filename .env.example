# === LLM Backend (choose one) ===
# Options: "bedrock" (default), "claude", "openai"
LLM_BACKEND=bedrock

# === AWS Bedrock (default) ===
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SESSION_TOKEN=optional-session-token
AWS_REGION=us-east-1
LLM_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0

# === Anthropic Direct (alternative) ===
# LLM_BACKEND=claude
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-20250514

# === OpenAI (alternative) ===
# LLM_BACKEND=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# === General ===
# How often to call LLM (1 = every step, N = every N steps, repeat last action in between)
LLM_CALL_INTERVAL=1

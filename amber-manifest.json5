{
  manifest_version: "0.1.0",
  program: {
    image: "ghcr.io/yunfeilu92/minecraft-purple-agent:latest",
    entrypoint: [
      "uv",
      "run",
      "src/server.py",
      "--host",
      "0.0.0.0",
      "--port",
      "9019"
    ],
    env: {
      LLM_BACKEND: "bedrock",
      LLM_MODEL: "us.anthropic.claude-haiku-4-5-20251001-v1:0",
      LLM_CALL_INTERVAL: "1",
      AWS_ACCESS_KEY_ID: "${config.aws_key}",
      AWS_SECRET_ACCESS_KEY: "${config.aws_secret}",
      AWS_REGION: "us-east-1"
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 9019 }
      ]
    }
  },
  config_schema: {
    type: "object",
    properties: {
      aws_key: { type: "string", secret: true },
      aws_secret: { type: "string", secret: true }
    },
    required: ["aws_key", "aws_secret"]
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" }
  },
  exports: {
    a2a: "a2a"
  }
}
